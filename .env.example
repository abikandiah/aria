# ── Model configuration ───────────────────────────────────────────────────────

# Default model when not set in aria.config.json or --model flag
ARIA_MODEL=claude-sonnet-4-6

# Option 1: Direct Anthropic
ANTHROPIC_API_KEY=your-key-here

# Option 2: Direct OpenAI
# OPENAI_API_KEY=sk-...

# Option 3: OpenRouter — one API key, access to every model
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...
# ARIA_MODEL=anthropic/claude-sonnet-4-6   (or openai/gpt-4o, meta-llama/..., etc.)

# Option 4: Ollama (local, no key required — set any non-empty string)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# ARIA_MODEL=llama3.1:8b

# Option 5: LM Studio or any other OpenAI-compatible endpoint
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
# ARIA_MODEL=your-local-model-name

# ── Config file ───────────────────────────────────────────────────────────────
# Path to aria.config.json (default: ./aria.config.json)
# ARIA_CONFIG=./aria.config.json

# ── Serve mode (uvicorn / Docker) ─────────────────────────────────────────────
# Role to activate when running as an HTTP service (default: "default")
# ARIA_ROLE=default

# Path to the SQLite session database used by the serve mode (default: ./aria.db)
# ARIA_DB_PATH=./aria.db

# Maximum output tokens per model response (default: 8096; claude-sonnet-4-6 supports up to 64000)
# ARIA_MAX_TOKENS=8096

# Maximum concurrent agent requests in serve mode (default: 10)
# ARIA_MAX_CONCURRENT_REQUESTS=10

# Tailscale auth key — used by docker-compose.yml to join the Tailscale network
# TS_AUTHKEY=tskey-auth-...

# ── Capability MCP servers ─────────────────────────────────────────────────────

# Web search — pick Brave or Tavily (see docs/capabilities.md)
# Brave Search: get a free key at brave.com/search/api (2,000 queries/month)
# BRAVE_API_KEY=BSA...
# Tavily: get a free key at tavily.com (1,000 searches/month, built for AI agents)
# TAVILY_API_KEY=tvly-...

# NAS credentials (for smb-mcp in cloud/Docker mode)
# SMB_NAS_USERNAME=myuser
# SMB_NAS_PASSWORD=mypassword

# Gmail (path to OAuth credentials JSON from Google Cloud Console)
# See docs/capabilities.md for setup instructions
# GMAIL_CREDENTIALS_PATH=/etc/aria/gmail-credentials.json

# ── Production note ────────────────────────────────────────────────────────────
# The example configs use `npx -y <pkg>@latest` for MCP servers. Before going
# to production, pin each package to a specific version (e.g. tavily-mcp@0.3.1)
# to prevent silent breaking changes on container rebuild. Run
# `npm view <pkg> version` to find the current stable version.
