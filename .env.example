# Anthropic API key (required)
ANTHROPIC_API_KEY=your-key-here

# SMB connection profiles — any SMB_<NAME>_HOST block defines a profile named <name>.
# See smb-mcp/.env.example for the full list of per-profile options.

# smb-mockups flat sandbox (make seed PROFILE=flat in smb-mockups)
SMB_NAS_HOST=samba-nas
SMB_NAS_USERNAME=
SMB_NAS_PASSWORD=

# Real NAS example
# SMB_OFFICE_HOST=192.168.1.100
# SMB_OFFICE_USERNAME=admin
# SMB_OFFICE_PASSWORD=secret
# SMB_OFFICE_DOMAIN=CORP
