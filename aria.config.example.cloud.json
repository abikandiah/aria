{
  "mcpServers": {
    "nas-files": {
      "command": "smb-mcp",
      "transport": "stdio",
      "env": {
        "SMB_NAS_HOST": "nas.tail12345.ts.net",
        "SMB_NAS_USERNAME": { "from": "env", "var": "SMB_NAS_USERNAME" },
        "SMB_NAS_PASSWORD": { "from": "env", "var": "SMB_NAS_PASSWORD" }
      },
      "write_tools": ["smb_write_file", "smb_delete", "smb_move", "smb_copy", "smb_mkdir"]
    },
    "web-search-brave": {
      "command": "npx",
      "transport": "stdio",
      "args": ["-y", "@brave/brave-search-mcp-server"],
      "env": {
        "BRAVE_API_KEY": { "from": "env", "var": "BRAVE_API_KEY" }
      },
      "write_tools": []
    },
    "web-search-tavily": {
      "command": "npx",
      "transport": "stdio",
      "args": ["-y", "tavily-mcp@latest"],
      "env": {
        "TAVILY_API_KEY": { "from": "env", "var": "TAVILY_API_KEY" }
      },
      "write_tools": []
    },
    "gmail": {
      "command": "npx",
      "transport": "stdio",
      "args": ["-y", "@gongrzhe/server-gmail-autoauth-mcp"],
      "env": {
        "GMAIL_CREDENTIALS_PATH": { "from": "env", "var": "GMAIL_CREDENTIALS_PATH" }
      },
      "write_tools": ["send_email", "create_draft", "reply_to_email", "forward_email", "delete_email", "trash_email", "modify_labels"]
    },
    "messaging-twilio": {
      "command": "npx",
      "transport": "stdio",
      "args": ["-y", "@twilio-labs/mcp"],
      "env": {
        "TWILIO_ACCOUNT_SID": { "from": "env", "var": "TWILIO_ACCOUNT_SID" },
        "TWILIO_AUTH_TOKEN": { "from": "env", "var": "TWILIO_AUTH_TOKEN" }
      },
      "write_tools": ["create_message"]
    },
    "nas-remote": {
      "transport": "streamable_http",
      "url": "https://nas.tail12345.ts.net:8080/mcp",
      "write_tools": ["write_file", "edit_file", "create_directory", "move_file", "delete_file"]
    }
  },
  "roles": {
    "default": {
      "model": "claude-sonnet-4-6",
      "servers": ["nas-files", "web-search-brave", "gmail"],
      "readonly": false,
      "persona": "default",
      "description": "Full access — NAS via Tailscale, web search, and email"
    },
    "analyst": {
      "model": "claude-sonnet-4-6",
      "servers": ["nas-files", "web-search-brave", "gmail"],
      "readonly": true,
      "persona": "analyst",
      "description": "Research — reads files, searches web, reads email. No writes."
    },
    "readonly": {
      "model": "claude-haiku-4-5-20251001",
      "servers": ["nas-files"],
      "readonly": true,
      "persona": "browse",
      "description": "Read-only file browsing — cheaper model, no web search or email"
    }
  }
}
